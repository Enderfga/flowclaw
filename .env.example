# ============================================================
# Council — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.

# ---------- Server ----------

# Server port (default: 3001)
PORT=3001

# ---------- AI Providers ----------

# OpenAI API key (for GPT-4o, etc.)
OPENAI_API_KEY=sk-...

# Anthropic API key (for Claude 4.6 models — uses native Messages API)
ANTHROPIC_API_KEY=sk-ant-...

# Google AI API key (for Gemini 3.1 models)
GOOGLE_API_KEY=AI...

# Force mock mode (all providers return mock responses, no API calls)
# COUNCIL_MOCK=true

# ---------- Database ----------

# SQLite database path (default: data/council.db)
# Set to :memory: for ephemeral in-memory storage (testing)
# COUNCIL_DB_PATH=/path/to/council.db
# COUNCIL_DB=:memory:
